{
  "name": "vacaciones-legendarias",
  "private": true,
  "scripts": {
    "dev": "pnpm db:push && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:seed": "pnpm --filter @repo/database db:seed",
    "db:seed:demo": "pnpm --filter @repo/database db:seed:demo",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "avatars:download": "node scripts/download-avatars.mjs",
    "avatars:sync": "node scripts/sync-avatars.mjs",
    "branding:sync": "node scripts/sync-branding.mjs",
    "branding:process": "node scripts/process-branding.mjs && node scripts/generate-pwa-icons.mjs && node scripts/sync-branding.mjs",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "benchmark:domain": "pnpm --filter @repo/database benchmark:domain"
  },
  "devDependencies": {
    "sharp": "^0.35.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
